<section class="search-page section">
  <div class="container">
    <h1>Search</h1>
    <form action="{{ routes.search_url }}" method="get" role="search">
      <input type="search" name="q" value="{{ search.terms | escape }}" placeholder="Search…" aria-label="Search">
      <button type="submit" class="btn btn--primary">Search</button>
    </form>
    {%- if search.performed -%}
      {%- if search.results_count == 0 -%}
        <p>No results for &ldquo;{{ search.terms }}&rdquo;.</p>
      {%- else -%}
        <p>{{ search.results_count }} result{% if search.results_count > 1 %}s{% endif %} for &ldquo;{{ search.terms }}&rdquo;</p>
        <ul>
          {%- for item in search.results -%}
            <li><a href="{{ item.url }}">{{ item.title }}</a></li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
    {%- endif -%}
  </div>
</section>
