<section class="account-page container" aria-labelledby="account-heading">

  <header class="account-header">
    <h1 id="account-heading" class="account-page__title">
      Welcome back, {{ customer.first_name }}
    </h1>
    <a href="{{ routes.account_logout_url }}" class="btn btn--ghost btn--sm">Sign Out</a>
  </header>

  <div class="account-layout">

    {%- comment -%}── Order History ──────────────────────────────────────{%- endcomment -%}
    <section class="account-orders" aria-labelledby="orders-heading">
      <h2 id="orders-heading" class="account-section__title">Order History</h2>

      {%- if customer.orders.size > 0 -%}
        <div class="orders-table-wrap">
          <table class="orders-table">
            <thead>
              <tr>
                <th scope="col">Order</th>
                <th scope="col">Date</th>
                <th scope="col">Status</th>
                <th scope="col">Total</th>
                <th scope="col"></th>
              </tr>
            </thead>
            <tbody>
              {%- for order in customer.orders -%}
                <tr>
                  <td>
                    <a href="{{ order.customer_url }}">{{ order.name }}</a>
                  </td>
                  <td>{{ order.created_at | date: '%B %d, %Y' }}</td>
                  <td>
                    <span class="order-status order-status--{{ order.financial_status }}">
                      {{ order.financial_status_label }}
                    </span>
                  </td>
                  <td>{{ order.total_price | money }}</td>
                  <td>
                    <a href="{{ order.customer_url }}" class="link-arrow">View &rarr;</a>
                  </td>
                </tr>
              {%- endfor -%}
            </tbody>
          </table>
        </div>
      {%- else -%}
        <p class="account-empty">You haven't placed any orders yet.</p>
        <a href="/pages/memberships" class="btn btn--primary">View Memberships</a>
      {%- endif -%}
    </section>

    {%- comment -%}── Account Details ────────────────────────────────────{%- endcomment -%}
    <aside class="account-details" aria-labelledby="details-heading">
      <h2 id="details-heading" class="account-section__title">Account Details</h2>

      <address class="account-address">
        {{ customer.email }}<br>
        {%- if customer.default_address -%}
          {{ customer.default_address | format_address }}
        {%- else -%}
          <span class="account-empty">No default address on file.</span>
        {%- endif -%}
      </address>

      <a href="{{ routes.account_addresses_url }}" class="btn btn--ghost btn--sm account-details__edit">
        Manage Addresses
      </a>
    </aside>
  </div>

</section>
