{%- liquid
  assign meta_title = blank
  assign meta_desc  = blank

  case template.name
    when 'index'
      assign meta_title = settings.seo_title_home
      assign meta_desc  = settings.seo_description_home
    when 'collection'
      assign meta_title = settings.seo_title_collection | default: collection.title
      assign meta_desc  = settings.seo_description_collection | default: collection.description | strip_html | truncate: 160
    when 'product'
      assign meta_title = page_title | default: product.title
      assign meta_desc  = page_description | default: product.description | strip_html | truncate: 160
    when 'page'
      case template.suffix
        when 'memberships'
          assign meta_title = settings.seo_title_memberships
          assign meta_desc  = settings.seo_description_memberships
        when 'passes'
          assign meta_title = settings.seo_title_passes
          assign meta_desc  = settings.seo_description_passes
        when 'personal-training'
          assign meta_title = settings.seo_title_pt
          assign meta_desc  = settings.seo_description_pt
        when 'about'
          assign meta_title = settings.seo_title_about
          assign meta_desc  = settings.seo_description_about
        when 'contact'
          assign meta_title = settings.seo_title_contact
          assign meta_desc  = settings.seo_description_contact
        else
          assign meta_title = page_title | default: page.title
          assign meta_desc  = page_description | default: page.content | strip_html | truncate: 160
      endcase
    else
      assign meta_title = page_title
      assign meta_desc  = page_description
  endcase

  if meta_title == blank
    assign meta_title = page_title | default: settings.gym_name | default: shop.name
  endif
  if meta_desc == blank
    assign meta_desc = page_description | default: settings.seo_description | default: shop.description
  endif

  if page_image
    assign og_image = page_image | image_url: width: 1200 | prepend: 'https:'
  elsif settings.share_image
    assign og_image = settings.share_image | image_url: width: 1200 | prepend: 'https:'
  endif
-%}
<title>
  {{- meta_title -}}
  {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
  {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
  {%- unless meta_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
</title>
{%- if meta_desc != blank -%}
  <meta name="description" content="{{ meta_desc | escape }}">
{%- endif -%}
<meta property="og:title" content="{{ meta_title | escape }}">
{%- if meta_desc != blank -%}
  <meta property="og:description" content="{{ meta_desc | escape }}">
{%- endif -%}
{%- if og_image != blank -%}
  <meta property="og:image" content="{{ og_image }}">
  <meta name="twitter:image" content="{{ og_image }}">
{%- endif -%}
<meta name="twitter:title" content="{{ meta_title | escape }}">
{%- if meta_desc != blank -%}
  <meta name="twitter:description" content="{{ meta_desc | escape }}">
{%- endif -%}
