{%- if template.name == 'page' and template.suffix == 'personal-training' -%}
{%- comment -%}── Schema.org: Service (Personal Training) — only on dedicated PT page ──{%- endcomment -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Service",
  "name": {{ section.settings.heading | default: 'Personal Training' | json }},
  "description": {{ section.settings.subheading | default: "Expert 1-on-1 and semi-private personal training sessions inside Compound Gym's private facility in Houston, TX." | json }},
  "provider": {
    "@type": "GymOrHealthClub",
    "name": {{ settings.gym_name | default: shop.name | json }},
    "url": {{ shop.url | json }},
    "address": {
      "@type": "PostalAddress",
      "streetAddress": {{ settings.address_street | json }},
      "addressLocality": {{ settings.address_city | json }},
      "addressRegion": {{ settings.address_state | json }},
      "postalCode": {{ settings.address_zip | json }},
      "addressCountry": "US"
    }
  },
  "areaServed": {
    "@type": "City",
    "name": "Houston",
    "addressRegion": "TX",
    "addressCountry": "US"
  },
  "serviceType": "Personal Training",
  "offers": [
    {
      "@type": "Offer",
      "name": "1-on-1 Personal Training",
      "description": "Fully private 60-minute coaching sessions"
    },
    {
      "@type": "Offer",
      "name": "Semi-Private Personal Training",
      "description": "Small-group coaching with 2-4 clients per session"
    }
  ]
}
</script>
{%- endif -%}

<section class="pt-services section" aria-labelledby="pt-heading-{{ section.id }}">
  <div class="container">

    {%- comment -%}── Page Header ────────────────────────────────────────{%- endcomment -%}
    <header class="section__header">
      {%- if section.settings.heading_level == 'h2' -%}
        <h2 id="pt-heading-{{ section.id }}" class="section__heading">
          {{ section.settings.heading }}
        </h2>
      {%- else -%}
        <h1 id="pt-heading-{{ section.id }}" class="section__heading">
          {{ section.settings.heading }}
        </h1>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="section__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
      {%- if section.settings.free_intro_label != blank -%}
        <span class="badge badge--accent">{{ section.settings.free_intro_label }}</span>
      {%- endif -%}
      {%- if section.settings.cta_label != blank -%}
        <div class="pt-header-cta">
          <a href="{{ section.settings.cta_url | default: '#pt-contact' }}" class="btn btn--primary btn--lg">
            {{ section.settings.cta_label }}
          </a>
        </div>
      {%- endif -%}
    </header>

    {%- comment -%}── Service Formats ────────────────────────────────────{%- endcomment -%}
    <div class="pt-formats">
      <article class="pt-format-card">
        <h2 class="pt-format-card__title">1&#8209;on&#8209;1 Personal Training</h2>
        <p class="pt-format-card__desc">Fully private sessions — your coach is with you and only you the entire 60-minute session. Built around your specific goals: strength, physique, performance, or all three.</p>
      </article>
      <article class="pt-format-card">
        <h2 class="pt-format-card__title">Semi-Private Training</h2>
        <p class="pt-format-card__desc">2&ndash;4 clients training simultaneously under one coach, with a shared but structured program. The same expert guidance at a more accessible price point.</p>
      </article>
    </div>

    {%- comment -%}── Process Steps ──────────────────────────────────────{%- endcomment -%}
    {%- if section.settings.show_process -%}
      <div class="pt-process" aria-label="How personal training works">
        <h2 class="pt-process__heading">Your Path to Results</h2>
        <ol class="pt-process__list" role="list">
          <li class="pt-process__step">
            <span class="pt-process__number" aria-hidden="true">1</span>
            <div class="pt-process__content">
              <h3 class="pt-process__title">Intro Call</h3>
              <p>We start with a quick call to understand your goals, current fitness level, and schedule.</p>
            </div>
          </li>
          <li class="pt-process__step">
            <span class="pt-process__number" aria-hidden="true">2</span>
            <div class="pt-process__content">
              <h3 class="pt-process__title">Movement Assessment</h3>
              <p>Your first session includes a full movement screen so we can build your program from data, not guesswork.</p>
            </div>
          </li>
          <li class="pt-process__step">
            <span class="pt-process__number" aria-hidden="true">3</span>
            <div class="pt-process__content">
              <h3 class="pt-process__title">Custom Program Design</h3>
              <p>Your trainer builds a program tailored to your specific goals &mdash; strength, physique, performance, or all three.</p>
            </div>
          </li>
          <li class="pt-process__step">
            <span class="pt-process__number" aria-hidden="true">4</span>
            <div class="pt-process__content">
              <h3 class="pt-process__title">Train &amp; Progress</h3>
              <p>Show up, execute, and track measurable results. Adjustments are made every session to keep you moving forward.</p>
            </div>
          </li>
        </ol>
      </div>
    {%- endif -%}

    {%- comment -%}── Trainer Card ───────────────────────────────────────{%- endcomment -%}
    {%- if section.settings.show_trainer -%}
      <div class="pt-trainer">
        <h2 class="pt-trainer__heading">Coached by the Best</h2>
        {%- render 'trainer-card',
          name: section.settings.trainer_name,
          credentials: section.settings.trainer_credentials,
          bio: section.settings.trainer_bio,
          image: section.settings.trainer_image,
          years: section.settings.trainer_years,
          clients: section.settings.trainer_clients,
          cert: section.settings.trainer_cert
        -%}
      </div>
    {%- endif -%}

    {%- comment -%}── Contact / Inquiry Form ─────────────────────────────{%- endcomment -%}
    <div id="pt-contact" class="pt-contact">
      <h2 class="pt-contact__heading">Interested in Training?</h2>
      <p class="pt-contact__desc">Fill out the form below and we&rsquo;ll reach out within 1 business day to discuss getting you started.</p>

      {%- form 'contact', id: 'pt-inquiry-form' -%}
        {%- if form.posted_successfully? -%}
          <div class="form-success" role="alert">
            <p>Thanks! We&rsquo;ll be in touch within 1 business day.</p>
          </div>
        {%- else -%}
          {%- if form.errors -%}
            <div class="form-errors" role="alert">
              <ul>
                {%- for error in form.errors -%}
                  <li>{{ error | capitalize }}: {{ form.errors.messages[error] }}</li>
                {%- endfor -%}
              </ul>
            </div>
          {%- endif -%}

          <div class="form-row form-row--two">
            <div class="form-field">
              <label for="ContactFirstName" class="form-label">First name <span aria-hidden="true">*</span></label>
              <input type="text" id="ContactFirstName" name="contact[first_name]" class="form-input" required autocomplete="given-name">
            </div>
            <div class="form-field">
              <label for="ContactLastName" class="form-label">Last name</label>
              <input type="text" id="ContactLastName" name="contact[last_name]" class="form-input" autocomplete="family-name">
            </div>
          </div>

          <div class="form-row form-row--two">
            <div class="form-field">
              <label for="ContactEmail" class="form-label">Email address <span aria-hidden="true">*</span></label>
              <input type="email" id="ContactEmail" name="contact[email]" class="form-input" required autocomplete="email">
            </div>
            <div class="form-field">
              <label for="ContactPhone" class="form-label">Phone number</label>
              <input type="tel" id="ContactPhone" name="contact[phone]" class="form-input" autocomplete="tel">
            </div>
          </div>

          <div class="form-field">
            <label for="ContactInterest" class="form-label">I&rsquo;m interested in&hellip;</label>
            <select id="ContactInterest" name="contact[interest]" class="form-select">
              <option value="">Select an option</option>
              <option value="1-on-1 Personal Training">1-on-1 Personal Training</option>
              <option value="Semi-Private Training">Semi-Private Training (Small Group)</option>
              <option value="Not Sure Yet">Not Sure Yet &mdash; Help Me Decide</option>
            </select>
          </div>

          <div class="form-field">
            <label for="ContactBody" class="form-label">Tell us about your goals (optional)</label>
            <textarea id="ContactBody" name="contact[body]" class="form-textarea" rows="4"></textarea>
          </div>

          <button type="submit" class="btn btn--primary btn--lg">Get In Touch</button>
          <p class="form-note">No commitments. We&rsquo;ll answer your questions and guide you to the right fit.</p>
        {%- endif -%}
      {%- endform -%}
    </div>

    {%- comment -%}── FAQ ────────────────────────────────────────────────{%- endcomment -%}
    {%- if section.settings.show_faq -%}
      <div class="pt-faq" aria-label="Personal training FAQ">
        <h2 class="pt-faq__heading">Personal Training FAQ</h2>
        <dl class="faq-list">
          <dt class="faq-question">How long are the sessions?</dt>
          <dd class="faq-answer">All sessions are 60 minutes. This includes warm-up, working sets, and any cool-down or mobility work your trainer programs for that day.</dd>
          <dt class="faq-question">What&rsquo;s the difference between 1-on-1 and semi-private?</dt>
          <dd class="faq-answer">1-on-1 sessions are fully private &mdash; your coach is with you and only you the entire session. Semi-private sessions have 2&ndash;4 clients training simultaneously under one coach. Both formats take place inside Compound&rsquo;s private facility.</dd>
          <dt class="faq-question">Do I need prior training experience?</dt>
          <dd class="faq-answer">Not at all. We work with all levels &mdash; from complete beginners to competitive athletes. Your program is built from scratch based on where you are right now.</dd>
          <dt class="faq-question">What should I bring to my first session?</dt>
          <dd class="faq-answer">Just show up in workout clothes and bring water. We have all the equipment you need. For your first session, come ready for a movement assessment &mdash; no heavy lifting required.</dd>
          <dt class="faq-question">How do I cancel or reschedule?</dt>
          <dd class="faq-answer">We ask for at least 24 hours notice to cancel or reschedule. Late cancellations or no-shows may be counted against your session package.</dd>
          <dt class="faq-question">Can I get a free consultation first?</dt>
          <dd class="faq-answer">Yes &mdash; fill out the form above and we&rsquo;ll schedule a free 1-hour intro session to answer your questions and make sure we&rsquo;re the right fit before you book anything.</dd>
        </dl>
      </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Personal Training",
  "settings": [
    {
      "type": "header",
      "content": "SEO",
      "info": "These values take highest priority. Leave blank to use the per-page defaults from Theme Settings → SEO — Per Page, or the page title/description from Shopify Admin."
    },
    {
      "type": "text",
      "id": "seo_title",
      "label": "Meta title override"
    },
    {
      "type": "textarea",
      "id": "seo_description",
      "label": "Meta description override",
      "info": "Max 160 characters recommended."
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Page heading",
      "default": "Personal Training"
    },
    {
      "type": "select",
      "id": "heading_level",
      "label": "Heading level",
      "options": [
        {
          "value": "h1",
          "label": "H1 (use on dedicated PT page)"
        },
        {
          "value": "h2",
          "label": "H2 (use on homepage teaser)"
        }
      ],
      "default": "h1",
      "info": "Set to H2 when this section appears alongside other H1 headings (e.g. homepage)."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Expert coaching built around you — 1-on-1 and semi-private sessions inside Compound's private facility."
    },
    {
      "type": "text",
      "id": "free_intro_label",
      "label": "Free intro badge label",
      "default": "Free 1-Hour Intro Session"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Header CTA label",
      "default": "Get In Touch"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Header CTA URL (defaults to #pt-contact)"
    },
    {
      "type": "checkbox",
      "id": "show_process",
      "label": "Show process steps",
      "default": true
    },
    {
      "type": "header",
      "content": "Trainer Profile"
    },
    {
      "type": "checkbox",
      "id": "show_trainer",
      "label": "Show trainer profile",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "trainer_image",
      "label": "Trainer photo"
    },
    {
      "type": "text",
      "id": "trainer_name",
      "label": "Trainer name",
      "default": "Your Trainer Name"
    },
    {
      "type": "text",
      "id": "trainer_credentials",
      "label": "Credentials / title",
      "default": "NSCA-CSCS · Powerlifting Coach · 10+ Years"
    },
    {
      "type": "textarea",
      "id": "trainer_bio",
      "label": "Trainer bio",
      "default": "A no-nonsense, data-driven approach to coaching. Whether you're chasing strength records or reshaping your body, every session is built around measurable progress — not guesswork."
    },
    {
      "type": "text",
      "id": "trainer_years",
      "label": "Years coaching",
      "default": "10+"
    },
    {
      "type": "text",
      "id": "trainer_clients",
      "label": "Clients trained",
      "default": "200+"
    },
    {
      "type": "text",
      "id": "trainer_cert",
      "label": "Primary certification",
      "default": "NSCA"
    },
    {
      "type": "header",
      "content": "FAQ"
    },
    {
      "type": "checkbox",
      "id": "show_faq",
      "label": "Show FAQ",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Personal Training"
    }
  ]
}
{% endschema %}
