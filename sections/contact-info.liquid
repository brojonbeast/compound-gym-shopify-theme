<section class="contact-info section" aria-labelledby="contact-heading-{{ section.id }}">
  <div class="container">

    <header class="section__header">
      <h1 id="contact-heading-{{ section.id }}" class="section__heading">
        {{ section.settings.heading }}
      </h1>
    </header>

    {%- comment -%}── Schema.org: LocalBusiness with address ─────────────{%- endcomment -%}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "GymOrHealthClub",
      "name": {{ settings.gym_name | default: shop.name | json }},
      "address": {
        "@type": "PostalAddress",
        "streetAddress": {{ settings.address_street | json }},
        "addressLocality": {{ settings.address_city | json }},
        "addressRegion": {{ settings.address_state | json }},
        "postalCode": {{ settings.address_zip | json }},
        "addressCountry": "US"
      },
      "telephone": {{ settings.phone | json }},
      "email": {{ settings.email | json }},
      "openingHours": {{ settings.hours | json }},
      "hasMap": "https://maps.google.com/?q=Compound+Gym+7523+South+Fwy+Houston+TX"
    }
    </script>

    <div class="contact-layout">

      {%- comment -%}── Contact Details ────────────────────────────────────{%- endcomment -%}
      <address class="contact-details">
        <h2 class="contact-details__heading">Get in Touch</h2>
        <dl class="contact-details__list">
          {%- if settings.address_street != blank -%}
            <dt>Address</dt>
            <dd>
              {{ settings.address_street }}<br>
              {{ settings.address_city }}, {{ settings.address_state }} {{ settings.address_zip }}
            </dd>
          {%- endif -%}
          {%- if settings.hours != blank -%}
            <dt>Hours</dt>
            <dd>{{ settings.hours }}</dd>
          {%- endif -%}
          {%- if settings.phone != blank -%}
            <dt>Phone</dt>
            <dd>
              <a href="tel:{{ settings.phone | remove: ' ' | remove: '-' | remove: '(' | remove: ')' }}">
                {{ settings.phone }}
              </a>
            </dd>
          {%- endif -%}
          {%- if settings.email != blank -%}
            <dt>Email</dt>
            <dd>
              <a href="mailto:{{ settings.email }}">{{ settings.email }}</a>
            </dd>
          {%- endif -%}
        </dl>

        {%- render 'social-links' -%}
      </address>

      {%- comment -%}── Map ────────────────────────────────────────────────{%- endcomment -%}
      {%- if section.settings.show_map and settings.maps_embed_url != blank -%}
        <div class="contact-map" aria-label="Map showing {{ settings.gym_name | default: shop.name }} location">
          <iframe
            src="{{ settings.maps_embed_url }}"
            width="100%"
            height="400"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="{{ settings.gym_name | default: shop.name }} on Google Maps"
          ></iframe>
        </div>
      {%- endif -%}

    </div>

  </div>
</section>

{% schema %}
{
  "name": "Contact Info",
  "settings": [
    {
      "type": "header",
      "content": "SEO",
      "info": "These values take highest priority. Leave blank to use the per-page defaults from Theme Settings → SEO — Per Page, or the page title/description from Shopify Admin."
    },
    {
      "type": "text",
      "id": "seo_title",
      "label": "Meta title override"
    },
    {
      "type": "textarea",
      "id": "seo_description",
      "label": "Meta description override",
      "info": "Max 160 characters recommended."
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Page heading (H1)",
      "default": "Find Us"
    },
    {
      "type": "checkbox",
      "id": "show_map",
      "label": "Show Google Map",
      "default": true,
      "info": "Uses the Google Maps embed URL from Theme Settings → Google Maps."
    }
  ],
  "presets": [
    {
      "name": "Contact Info"
    }
  ]
}
{% endschema %}
