<section class="gym-highlights section" aria-labelledby="highlights-heading-{{ section.id }}">
  <div class="container">

    <header class="section__header">
      <h2 id="highlights-heading-{{ section.id }}" class="section__heading">
        {{ section.settings.heading }}
      </h2>
      {%- if section.settings.subheading != blank -%}
        <p class="section__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </header>

    {%- comment -%}── Six Facility Zones ─────────────────────────────────{%- endcomment -%}
    <div class="highlights-grid" role="list" aria-label="Facility zones">
      {%- for block in section.blocks -%}
        <article class="highlight-card" role="listitem" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            <div class="highlight-card__image-wrap">
              {{- block.settings.image | image_url: width: 600 | image_tag:
                  class: 'highlight-card__image',
                  alt: block.settings.name,
                  loading: 'lazy',
                  widths: '300, 400, 600' -}}
            </div>
          {%- endif -%}
          <div class="highlight-card__body">
            <div class="highlight-card__zone" aria-hidden="true">{{ block.settings.zone_label }}</div>
            <h3 class="highlight-card__name">{{ block.settings.name }}</h3>
            <p class="highlight-card__detail">{{ block.settings.detail }}</p>
          </div>
        </article>
      {%- else -%}
        <article class="highlight-card" role="listitem">
          <div class="highlight-card__body">
            <div class="highlight-card__zone" aria-hidden="true">Zone 01</div>
            <h3 class="highlight-card__name">Powerlifting Section</h3>
            <p class="highlight-card__detail">Competition Grade Platforms</p>
          </div>
        </article>
        <article class="highlight-card" role="listitem">
          <div class="highlight-card__body">
            <div class="highlight-card__zone" aria-hidden="true">Zone 02</div>
            <h3 class="highlight-card__name">Dumbbell Section</h3>
            <p class="highlight-card__detail">5lb &ndash; 150lb Precision Steel</p>
          </div>
        </article>
        <article class="highlight-card" role="listitem">
          <div class="highlight-card__body">
            <div class="highlight-card__zone" aria-hidden="true">Zone 03</div>
            <h3 class="highlight-card__name">Lower Body / Legs</h3>
            <p class="highlight-card__detail">Hammer Strength Specialized</p>
          </div>
        </article>
        <article class="highlight-card" role="listitem">
          <div class="highlight-card__body">
            <div class="highlight-card__zone" aria-hidden="true">Zone 04</div>
            <h3 class="highlight-card__name">Posing Room</h3>
            <p class="highlight-card__detail">Curated Lighting &amp; Mirrors</p>
          </div>
        </article>
        <article class="highlight-card" role="listitem">
          <div class="highlight-card__body">
            <div class="highlight-card__zone" aria-hidden="true">Zone 05</div>
            <h3 class="highlight-card__name">Infrared Saunas</h3>
            <p class="highlight-card__detail">Detox &amp; Muscle Recovery</p>
          </div>
        </article>
        <article class="highlight-card" role="listitem">
          <div class="highlight-card__body">
            <div class="highlight-card__zone" aria-hidden="true">Zone 06</div>
            <h3 class="highlight-card__name">Upper Body Section</h3>
            <p class="highlight-card__detail">Specialized Isolation Equipment</p>
          </div>
        </article>
      {%- endfor -%}
    </div>

    {%- comment -%}── Equipment Brands ───────────────────────────────────{%- endcomment -%}
    {%- if section.settings.show_brands -%}
      <div class="brands-strip" aria-label="Equipment brands">
        <p class="brands-strip__label">Engineered with</p>
        <ul class="brands-strip__list" role="list">
          <li>Rogue</li>
          <li>Eleiko</li>
          <li>Hammer Strength</li>
          <li>Arsenal Strength</li>
          <li>Precor</li>
          <li>StairMaster</li>
          <li>Watson</li>
        </ul>
      </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Gym Highlights",
  "settings": [
    {
      "type": "header",
      "content": "SEO",
      "info": "Optional meta title/description override for this section. Leave blank to use page defaults."
    },
    {
      "type": "text",
      "id": "seo_title",
      "label": "Meta title override"
    },
    {
      "type": "textarea",
      "id": "seo_description",
      "label": "Meta description override",
      "info": "Max 160 characters."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "A True Private Training Experience"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Section subheading",
      "default": "Six purpose-built zones engineered for serious athletes."
    },
    {
      "type": "checkbox",
      "id": "show_brands",
      "label": "Show equipment brands",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "zone",
      "name": "Zone",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Zone photo",
          "info": "Recommended: 600×400px or wider. Optional."
        },
        {
          "type": "text",
          "id": "zone_label",
          "label": "Zone label",
          "default": "Zone 01"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Zone name",
          "default": "Powerlifting Section"
        },
        {
          "type": "text",
          "id": "detail",
          "label": "Zone detail",
          "default": "Competition Grade Platforms"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Gym Highlights",
      "blocks": [
        {
          "type": "zone",
          "settings": {
            "zone_label": "Zone 01",
            "name": "Powerlifting Section",
            "detail": "Competition Grade Platforms"
          }
        },
        {
          "type": "zone",
          "settings": {
            "zone_label": "Zone 02",
            "name": "Dumbbell Section",
            "detail": "5lb – 150lb Precision Steel"
          }
        },
        {
          "type": "zone",
          "settings": {
            "zone_label": "Zone 03",
            "name": "Lower Body / Legs",
            "detail": "Hammer Strength Specialized"
          }
        },
        {
          "type": "zone",
          "settings": {
            "zone_label": "Zone 04",
            "name": "Posing Room",
            "detail": "Curated Lighting & Mirrors"
          }
        },
        {
          "type": "zone",
          "settings": {
            "zone_label": "Zone 05",
            "name": "Infrared Saunas",
            "detail": "Detox & Muscle Recovery"
          }
        },
        {
          "type": "zone",
          "settings": {
            "zone_label": "Zone 06",
            "name": "Upper Body Section",
            "detail": "Specialized Isolation Equipment"
          }
        }
      ]
    }
  ]
}
{% endschema %}
