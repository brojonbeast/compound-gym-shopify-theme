<section class="gym-highlights section" aria-labelledby="highlights-heading-{{ section.id }}">
  <div class="container">

    <header class="section__header">
      <h2 id="highlights-heading-{{ section.id }}" class="section__heading">
        {{ section.settings.heading }}
      </h2>
      {%- if section.settings.subheading != blank -%}
        <p class="section__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </header>

    {%- comment -%}── Six Facility Zones ─────────────────────────────────{%- endcomment -%}
    <div class="highlights-grid" role="list" aria-label="Facility zones">
      {%- for block in section.blocks -%}
        <article class="highlight-card" role="listitem" {{ block.shopify_attributes }}>
          <div class="highlight-card__inner">
            {%- if block.settings.image != blank -%}
              {{- block.settings.image | image_url: width: 800 | image_tag:
                  class: 'highlight-card__image',
                  alt: block.settings.name,
                  loading: 'lazy',
                  widths: '400, 600, 800' -}}
            {%- else -%}
              <div class="highlight-card__placeholder"></div>
            {%- endif -%}
            <div class="highlight-card__overlay" aria-hidden="true"></div>
            <span class="highlight-card__badge">{{ block.settings.zone_label }}</span>
            <div class="highlight-card__text">
              <h3 class="highlight-card__name">{{ block.settings.name }}</h3>
              {%- if block.settings.detail != blank -%}
                <p class="highlight-card__detail">{{ block.settings.detail }}</p>
              {%- endif -%}
            </div>
          </div>
        </article>
      {%- else -%}
        {%- assign fallback_zones = "Zone 01|Powerlifting Section|Competition Grade Platforms,Zone 02|Dumbbell Section|5lb – 150lb Precision Steel,Zone 03|Lower Body / Legs|Hammer Strength Specialized,Zone 04|Posing Room|Curated Lighting & Mirrors,Zone 05|Infrared Saunas|Detox & Muscle Recovery,Zone 06|Upper Body Section|Specialized Isolation Equipment" | split: "," -%}
        {%- for zone in fallback_zones -%}
          {%- assign parts = zone | split: "|" -%}
          <article class="highlight-card" role="listitem">
            <div class="highlight-card__inner">
              <div class="highlight-card__placeholder"></div>
              <div class="highlight-card__overlay" aria-hidden="true"></div>
              <span class="highlight-card__badge">{{ parts[0] }}</span>
              <div class="highlight-card__text">
                <h3 class="highlight-card__name">{{ parts[1] }}</h3>
                <p class="highlight-card__detail">{{ parts[2] }}</p>
              </div>
            </div>
          </article>
        {%- endfor -%}
      {%- endfor -%}
    </div>

    {%- comment -%}── Equipment Brands ───────────────────────────────────{%- endcomment -%}
    {%- if section.settings.show_brands -%}
      <div class="brands-strip" aria-label="Equipment brands">
        <p class="brands-strip__label">Engineered with</p>
        <ul class="brands-strip__list" role="list">
          <li>Rogue</li>
          <li>Eleiko</li>
          <li>Hammer Strength</li>
          <li>Arsenal Strength</li>
          <li>Precor</li>
          <li>StairMaster</li>
          <li>Watson</li>
        </ul>
      </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Gym Highlights",
  "settings": [
    {
      "type": "header",
      "content": "SEO",
      "info": "Optional meta title/description override for this section. Leave blank to use page defaults."
    },
    {
      "type": "text",
      "id": "seo_title",
      "label": "Meta title override"
    },
    {
      "type": "textarea",
      "id": "seo_description",
      "label": "Meta description override",
      "info": "Max 160 characters."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "A True Private Training Experience"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Section subheading",
      "default": "Six purpose-built zones engineered for serious athletes."
    },
    {
      "type": "checkbox",
      "id": "show_brands",
      "label": "Show equipment brands",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "zone",
      "name": "Zone",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Zone photo",
          "info": "Recommended: 800×600px or wider."
        },
        {
          "type": "text",
          "id": "zone_label",
          "label": "Zone label",
          "default": "Zone 01"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Zone name",
          "default": "Powerlifting Section"
        },
        {
          "type": "text",
          "id": "detail",
          "label": "Zone detail",
          "default": "Competition Grade Platforms"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Gym Highlights",
      "blocks": [
        {
          "type": "zone",
          "settings": {
            "zone_label": "Zone 01",
            "name": "Powerlifting Section",
            "detail": "Competition Grade Platforms"
          }
        },
        {
          "type": "zone",
          "settings": {
            "zone_label": "Zone 02",
            "name": "Dumbbell Section",
            "detail": "5lb \u2013 150lb Precision Steel"
          }
        },
        {
          "type": "zone",
          "settings": {
            "zone_label": "Zone 03",
            "name": "Lower Body / Legs",
            "detail": "Hammer Strength Specialized"
          }
        },
        {
          "type": "zone",
          "settings": {
            "zone_label": "Zone 04",
            "name": "Posing Room",
            "detail": "Curated Lighting & Mirrors"
          }
        },
        {
          "type": "zone",
          "settings": {
            "zone_label": "Zone 05",
            "name": "Infrared Saunas",
            "detail": "Detox & Muscle Recovery"
          }
        },
        {
          "type": "zone",
          "settings": {
            "zone_label": "Zone 06",
            "name": "Upper Body Section",
            "detail": "Specialized Isolation Equipment"
          }
        }
      ]
    }
  ]
}
{% endschema %}
