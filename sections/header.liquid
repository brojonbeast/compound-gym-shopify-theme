<header class="site-header" role="banner">
  <div class="container site-header__inner">

    {%- comment -%}── Logo ───────────────────────────────────────────────{%- endcomment -%}
    <a href="{{ routes.root_url }}" class="site-header__logo" aria-label="{{ shop.name }} — Home">
      {%- if settings.logo -%}
        <img
          src="{{ settings.logo | image_url: width: settings.logo_width }}"
          alt="{{ shop.name }}"
          width="{{ settings.logo_width }}"
          height="auto"
          loading="eager"
          class="site-header__logo-img"
        >
      {%- else -%}
        <span class="site-header__logo-text">{{ settings.gym_name | default: shop.name }}</span>
      {%- endif -%}
    </a>

    {%- comment -%}── Desktop Navigation ─────────────────────────────────{%- endcomment -%}
    <nav class="site-nav" aria-label="Main navigation" role="navigation">
      <ul class="site-nav__list" role="list">
        {%- for link in linklists[settings.main_menu].links -%}
          <li class="site-nav__item{% if link.active %} site-nav__item--active{% endif %}">
            <a
              href="{{ link.url }}"
              class="site-nav__link"
              {% if link.active %}aria-current="page"{% endif %}
            >
              {{ link.title }}
            </a>
          </li>
        {%- else -%}
          <li class="site-nav__item"><a href="/pages/memberships" class="site-nav__link">Memberships</a></li>
          <li class="site-nav__item"><a href="/pages/passes" class="site-nav__link">Day Passes</a></li>
          <li class="site-nav__item"><a href="/pages/personal-training" class="site-nav__link">Personal Training</a></li>
          <li class="site-nav__item"><a href="/collections/apparel" class="site-nav__link">Shop</a></li>
          <li class="site-nav__item"><a href="/pages/about" class="site-nav__link">About</a></li>
          <li class="site-nav__item"><a href="/pages/contact" class="site-nav__link">Contact</a></li>
        {%- endfor -%}
      </ul>
    </nav>

    {%- comment -%}── Header Actions ─────────────────────────────────────{%- endcomment -%}
    <div class="site-header__actions">
      <a href="{{ routes.cart_url }}" class="site-header__cart" aria-label="Cart ({{ cart.item_count }} items)">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
          <circle cx="9" cy="21" r="1"></circle>
          <circle cx="20" cy="21" r="1"></circle>
          <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
        </svg>
        {%- if cart.item_count > 0 -%}
          <span class="site-header__cart-count" aria-hidden="true">{{ cart.item_count }}</span>
        {%- endif -%}
      </a>

      {%- if customer -%}
        <a href="{{ routes.account_url }}" class="btn btn--ghost btn--sm site-header__account">
          Account
        </a>
      {%- else -%}
        <a href="{{ routes.account_login_url }}" class="btn btn--ghost btn--sm site-header__account">
          Sign In
        </a>
      {%- endif -%}

      <a href="/pages/memberships" class="btn btn--primary btn--sm site-header__cta">
        Join Now
      </a>
    </div>

    {%- comment -%}── Mobile hamburger ───────────────────────────────────{%- endcomment -%}
    <button
      class="site-header__hamburger"
      id="mobile-menu-toggle"
      aria-controls="mobile-menu"
      aria-expanded="false"
      aria-label="Open navigation menu"
      type="button"
    >
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </button>
  </div>

  {%- comment -%}── Mobile Menu ────────────────────────────────────────{%- endcomment -%}
  <nav
    id="mobile-menu"
    class="mobile-menu"
    aria-label="Mobile navigation"
    aria-hidden="true"
    role="navigation"
  >
    <ul class="mobile-menu__list" role="list">
      {%- for link in linklists[settings.main_menu].links -%}
        <li class="mobile-menu__item">
          <a
            href="{{ link.url }}"
            class="mobile-menu__link"
            {% if link.active %}aria-current="page"{% endif %}
          >
            {{ link.title }}
          </a>
        </li>
      {%- else -%}
        <li class="mobile-menu__item"><a href="/pages/memberships" class="mobile-menu__link">Memberships</a></li>
        <li class="mobile-menu__item"><a href="/pages/passes" class="mobile-menu__link">Day Passes</a></li>
        <li class="mobile-menu__item"><a href="/pages/personal-training" class="mobile-menu__link">Personal Training</a></li>
        <li class="mobile-menu__item"><a href="/collections/apparel" class="mobile-menu__link">Shop</a></li>
        <li class="mobile-menu__item"><a href="/pages/about" class="mobile-menu__link">About</a></li>
        <li class="mobile-menu__item"><a href="/pages/contact" class="mobile-menu__link">Contact</a></li>
      {%- endfor -%}
    </ul>
    <div class="mobile-menu__cta">
      <a href="/pages/memberships" class="btn btn--primary btn--full">Join Now</a>
    </div>
  </nav>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "header",
      "content": "SEO",
      "info": "Optional meta title/description override for this section. Leave blank to use page defaults."
    },
    {
      "type": "text",
      "id": "seo_title",
      "label": "Meta title override"
    },
    {
      "type": "textarea",
      "id": "seo_description",
      "label": "Meta description override",
      "info": "Max 160 characters."
    }
  ]
}
{% endschema %}
